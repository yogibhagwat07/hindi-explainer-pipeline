# Copy karke naam .env rakho, phir apni keys bharo.
# .env gitignore mein hai - woh kabhi commit nahi hoga.
# Dono keys FREE hain aur credit card nahi maangti.
#
# Pexels : https://www.pexels.com/api/   -> sign up -> API key
# Pixabay: https://pixabay.com/api/docs/ -> sign up -> API key
#
# Ye do keys na hon to bhi fetchclips chalega - NASA, Wikimedia aur
# archive.org ko koi key nahi chahiye.

PEXELS_API_KEY=
PIXABAY_API_KEY=
